{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/e/:code", "destination": "/register.html" },
    { "source": "/admin/:code", "destination": "/admin.html" },
    { "source": "/bot/:code", "destination": "/bot.html" }
  ]
}
